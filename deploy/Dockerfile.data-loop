FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml uv.lock ./

RUN pip install --no-cache-dir uv && \
    uv pip install --system kafka-python pymysql sentence-transformers numpy

COPY gpr/ gpr/
COPY data/ data/
COPY agents/ agents/

CMD python data/flink/sample_cleaner.py --bootstrap-servers ${KAFKA_BOOTSTRAP:-localhost:9092} & \
    python data/flink/training_trigger.py --threshold ${SAMPLE_THRESHOLD:-500}
